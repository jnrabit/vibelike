# Vibelike Environment — Vorlage. Kopiere nach .env und fülle Werte ein.
# .env / .env.startup sind gitignored — niemals echte Keys committen.

# ── API Keys (optional, nur für Cloud-Boost-Stufe) ──
# Lokal-first: ohne diese Keys läuft alles über Ollama (siehe project_local_first_agentic).
GEMINI_API_KEY=""
ANTHROPIC_API_KEY=""
MISTRAL_API_KEY=""

# ── Modell-Auswahl (überschreibt config.py-Defaults) ──
# VIBELIKE_CODER_MODEL=deepseek-coder:6.7b-instruct
# VIBELIKE_ANALYSIS_MODEL=claude-haiku-4-5-20251001
# VIBELIKE_CODEGEN_BACKEND=claude

# ── Wissens-Vault (gross, extern; env → fallback → None) ──
# VIBELIKE_KNOWLEDGE_VAULT=/home/jnrabit/collect/data/monolith_archive_unified.json
# VIBELIKE_KNOWLEDGE_CACHE=/path/to/cache.pkl

# ── Retrieval-Daemon (siehe project_hotr_deployment) ──
# VIBELIKE_RETRIEVAL_URL=http://localhost:8810
